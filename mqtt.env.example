# ThermoPro MQTT Configuration
# Copy this file to /etc/thermopro/mqtt.env or ~/.config/thermopro/mqtt.env
# and customize with your settings

# MQTT Broker settings
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883

# MQTT Authentication (optional)
MQTT_USERNAME=homeassistant
MQTT_PASSWORD=your_secure_password_here
